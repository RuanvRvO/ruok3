# This environment variable is used in Production and Preview environments to deploy your Convex project
# This variable is not needed in development.
# You can create a Production or Preview deploy key at https://dashboard.convex.dev/project/settings#production-deploy-keys
CONVEX_DEPLOY_KEY=

# Your Convex site URL - this is automatically set by Convex
# Used for authentication callbacks
CONVEX_SITE_URL=https://your-deployment.convex.site

# Your frontend URL
# Used for generating links in emails (password reset, invitations, etc.)
# Production/Staging: Set to your deployed URL (e.g., https://www.yourapp.com)
# Local Development: Set to http://localhost:3000 or leave commented out (defaults to localhost:3000)
SITE_URL=https://www.yourapp.com

# Resend API key for sending emails (password resets, invitations, mood check-ins)
# Get your key at https://resend.com
RESEND_API_KEY=re_your_api_key_here

# Google Gemini API key for AI-generated mood check-in messages (optional)
# If not set, falls back to static pre-written messages
# Get your key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
